# Development Dockerfile for React frontend
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm ci

# Copy source code
COPY . .

## Expose port 5173 (Vite dev server)
EXPOSE 5173

## Start Vite dev server with host binding
CMD ["npm", "run", "dev", "--", "--host"]
